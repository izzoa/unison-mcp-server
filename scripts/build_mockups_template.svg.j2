<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg"
     width="{{ width }}" height="{{ height }}"
     viewBox="0 0 {{ width }} {{ height }}"
     font-family="'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
     font-size="14">
  <title>{{ title_escaped }}</title>
  <desc>{{ description_escaped }}</desc>
  <defs>
    <style>@font-face{font-family:'JetBrains Mono';font-style:normal;font-weight:400;src:url(data:font/ttf;base64,{{ font_base64 }}) format('truetype')}</style>
  </defs>
  <rect width="{{ width }}" height="{{ height }}" rx="10" fill="{{ palette.bg }}"/>
  <path d="M10 0h{{ width - 20 }}q10 0 10 10v22H0V10q0-10 10-10z" fill="{{ palette.titlebar_bg }}"/>
  <circle cx="20" cy="16" r="6" fill="#ff5f56"/>
  <circle cx="40" cy="16" r="6" fill="#ffbd2e"/>
  <circle cx="60" cy="16" r="6" fill="#27c93f"/>
  <text x="{{ width_half }}" y="21" fill="{{ palette.muted }}" font-size="12" text-anchor="middle">{{ title_escaped }}</text>
  <line x1="0" y1="32" x2="{{ width }}" y2="32" stroke="{{ palette.border }}" stroke-width="1"/>
{{ content_svg }}
</svg>
